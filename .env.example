# ─────────────────────────────────────────────────────────────
# NestMatch — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Google OAuth 2.0 Client ID (for Drive sync)
# No Maps API key needed — using OpenStreetMap (free, no billing)
REACT_APP_GDRIVE_CLIENT_ID=YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com
